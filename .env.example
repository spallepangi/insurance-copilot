# InsuranceCopilot AI - Environment Variables
# Copy to .env and fill in. Do not commit .env.

# Required for LLM (answer generation)
OPENAI_API_KEY=your_openai_key_here

# Optional: alternative LLM provider
# COHERE_API_KEY=

# Qdrant (default: http://localhost:6333 for local Docker)
QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=  # required for Qdrant Cloud

# Required for BAAI/bge-large-en and bge-reranker-large (if gated)
HUGGINGFACE_TOKEN=your_hf_token_here

# Optional: LangSmith monitoring
# LANGCHAIN_API_KEY=

# Optional: override default LLM model
# LLM_MODEL=gpt-4o-mini

# --- Production API (optional) ---
# If set, clients must send X-API-Key or Authorization: Bearer <key>
# API_KEY=your_secret_api_key_here
# RATE_LIMIT_PER_MINUTE=100
# HTTP_TIMEOUT_SECONDS=60

# Optional: alert on 5xx / high latency (Slack or Discord webhook)
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
